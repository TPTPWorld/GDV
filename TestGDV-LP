#!/bin/tcsh

if ($1 == "--remote") then
    set RemoteFlag = ""
    shift
else
    set RemoteFlag = "-T"
endif

#----Some proofs are deeeeep, e.g., SYN036+1 by E---3.2.0. Need a big stack for building the tree.
limit stacksize 32768
limit stacksize unlimited

set Basename = `basename $1 .p`
#DEFAULT set Command = "/home/tptp/ServiceTools/GDVDir/GDV -t 30 -s $RemoteFlag -M -L $1 -k TestFiles/TestsForLambdaPi/$1 -l -p TestFiles/TestsForLambdaPi/$1/${Basename}.p TestFiles/TestsForLambdaPi/$1/*---*.s"
#Leo-III-LP 
set Command = "/home/tptp/ServiceTools/GDVDir/GDV -P Leo-III-LP--- -t 30 -s $RemoteFlag -M -L $1 -k TestFiles/TestsForLambdaPi/$1 -l -p TestFiles/TestsForLambdaPi/$1/${Basename}.p TestFiles/TestsForLambdaPi/$1/*---*.s"
#Vampire-LP set Command = "/home/tptp/ServiceTools/GDVDir/GDV -P Vampire-LP--- -t 30 -s $RemoteFlag -M -L $1 -k TestFiles/TestsForLambdaPi/$1 -l -p TestFiles/TestsForLambdaPi/$1/${Basename}.p TestFiles/TestsForLambdaPi/$1/*---*.s"
echo "Running $Command"
$Command
